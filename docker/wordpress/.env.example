# Шаблон переменных окружения для WordPress + MySQL
# Создан: 2026-03-24
# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env

MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=wordpress
MYSQL_USER=your_db_user_here
MYSQL_PASSWORD=your_db_password_here

WORDPRESS_DB_HOST=db
WORDPRESS_DB_USER=your_db_user_here
WORDPRESS_DB_PASSWORD=your_db_password_here
WORDPRESS_DB_NAME=wordpress
